# Copy to .env (never commit .env). Used for local CLI deploys.
#
# Option A — interactive login (recommended on your Mac):
#   firebase login --reauth
#   npm run deploy
#
# Option B — CI token (from: npx firebase login:ci):
#   export FIREBASE_TOKEN="paste-token-here"
#   npm run deploy:token
#
FIREBASE_TOKEN=

# Option C — service account JSON path (same JSON you paste into GitHub Actions):
#   export GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/key.json"
#   npm run deploy
#
# GOOGLE_APPLICATION_CREDENTIALS=
